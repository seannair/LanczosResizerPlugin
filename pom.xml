<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://apache.org"
         xmlns:xsi="http://w3.org"
         xsi:schemaLocation="http://apache.org http://apache.org">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.microscopy</groupId>
    <artifactId>lanczos-resizer</artifactId>
    <version>1.0.0</version>
    <name>Lanczos Resizer</name>

    <properties>
        <maven.compiler.source>11</maven.compiler.source>
        <maven.compiler.target>11</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- Connects directly to your source directory folder -->
    <build>
        <sourceDirectory>src/main/java</sourceDirectory>
    </build>

    <!-- Configures the official stable SciJava servers -->
    <repositories>
        <repository>
            <id>scijava.public</id>
            <url>https://scijava.org</url>
        </repository>
    </repositories>

    <!-- Explicitly declaring the current production-grade release versions -->
    <dependencies>
        <!-- Core ImageJ Library -->
        <dependency>
            <groupId>net.imagej</groupId>
            <artifactId>ij</artifactId>
            <version>1.54g</version>
        </dependency>
        
        <!-- Core ImgLib2 Engine Package -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2</artifactId>
            <version>6.1.0</version>
        </dependency>

        <!-- Current stable production release of the ImageJ compatibility bridge -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2-ij</artifactId>
            <version>2.0.0</version>
        </dependency>

        <!-- Production transformation engine required for Affine transforms -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2-realtransform</artifactId>
            <version>3.1.1</version>
        </dependency>

        <!-- Stable algorithm layer required for Interpolators -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2-algorithm</artifactId>
            <version>0.13.0</version>
        </dependency>
    </dependencies>
</project>
