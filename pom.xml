<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://apache.org">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.microscopy</groupId>
    <artifactId>lanczos-resizer</artifactId>
    <version>1.0.0</version>
    <name>Lanczos Resizer</name>

    <properties>
        <maven.compiler.source>11</maven.compiler.source>
        <maven.compiler.target>11</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- Configure the location of your script -->
    <build>
        <sourceDirectory>src/main/java</sourceDirectory>
    </build>

    <!-- Configure the master stable SciJava ecosystem servers -->
    <repositories>
        <repository>
            <id>scijava.public</id>
            <url>https://scijava.org</url>
        </repository>
    </repositories>

    <!-- Explicitly declaring the current production-grade versions -->
    <dependencies>
        <!-- Core ImageJ Library -->
        <dependency>
            <groupId>net.imagej</groupId>
            <artifactId>ij</artifactId>
            <version>1.54g</version>
        </dependency>
        <!-- Core ImgLib2 Package -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2</artifactId>
            <version>6.1.0</version>
        </dependency>
        <!-- The critical bridge library containing net.imglib2.img.display.imagej -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2-ij</artifactId>
            <version>7.1.1</version>
        </dependency>
        <!-- Transform Algorithms needed for interpolation math -->
        <dependency>
            <groupId>net.imglib2</groupId>
            <artifactId>imglib2-algorithm</artifactId>
            <version>0.13.0</version>
        </dependency>
    </dependencies>
</project>
